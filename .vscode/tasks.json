{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "R",
			"args": [
				"--quiet",
				"--no-restore",
				"--no-save",
				"-e",
				"\"devtools::install()\""
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"label": "R: Build and Install",
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}